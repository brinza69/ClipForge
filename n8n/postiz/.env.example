# Copy to .env PER COUNTRY (one Postiz stack per country). Never commit real .env.
COUNTRY=ro
POSTIZ_PORT=5000
POSTIZ_URL=http://localhost:5000

# This country's residential/mobile proxy (the account's home network).
# Format: http://user:pass@host:port  — leave EMPTY for the native-country
# stack (e.g. your RO stack on a native RO connection needs no proxy).
COUNTRY_PROXY=

# Secrets
JWT_SECRET=change-me-long-random
DB_PASSWORD=change-me
