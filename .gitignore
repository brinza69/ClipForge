# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Ignore everything under data/ (API keys, tokens, media, voices, DB) …
data/*
# … EXCEPT the user's commentator presets + caption templates + fonts, which
# are real content worth versioning so they survive a fresh clone.
!data/commentators/
!data/caption_templates/
!data/fonts/
# comicbd.ttf = Comic Sans MS Bold — proprietary Microsoft font, NOT
# redistributable. Keep it local-only. (Inter + Bebas Neue are OFL — fine.)
data/fonts/comicbd.ttf
data_b/

# Runtime artifacts from dev.sh
logs/
.run/

# n8n runtime logs (the workflow JSON + README are tracked)
n8n/*.log

server/.venv/

*.db

*.db-journal

.env.local

# Python cache
__pycache__/
*.pyc
*.pyo

# Claude Code project files
.claude/

# Test scripts
test.py
server/test_transcribe.py
.env.*
!.env.example
node_modules/
projects/
exports/
audio/
images/
videos/
